# .env.example - Copy this to .env and fill with your values
# DO NOT COMMIT your real .env to version control.

# Supabase HTTP keys (used by client-side and server integrations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# Database connection (Option A - preferred): full connection string
# Use this if you prefer a single connection string (works on most hosts/devices)
# Example: postgres://postgres:password@db.project.supabase.co:5432/postgres
SUPABASE_DB_CONNECTION=

# Database connection (Option B): separate fields (used by some apps)
# If both SUPABASE_DB_CONNECTION and the fields below exist, code may prefer SUPABASE_DB_CONNECTION.
SUPABASE_DB_HOST=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_PORT=5432

# SSL settings (string values). On modern Supabase projects SSL is required.
# Set to "true" to enable SSL (the app should translate to ssl:{ rejectUnauthorized:false } if needed).
SUPABASE_DB_SSL=true

# Optional fallback DATABASE_URL (common in many hosting providers)
DATABASE_URL=

# App settings
PORT=3000
NODE_ENV=development

# Paths (relative to project root)
PUBLIC_PATH=./public
UPLOAD_PATH=./database/pictures
SUPABASE_STORAGE_BUCKET=profile-pictures

# Usage notes:
# 1. Copy this file to .env in the project root: 
#    - PowerShell: Copy-Item .env.example .env
#    - CMD: copy .env.example .env
#    - macOS / Linux: cp .env.example .env
# 2. Fill in real secrets from your Supabase project (Project → Settings → Database / API keys).
# 3. If you get SSL errors, ensure your app's DB client sets ssl:true and, for local testing only,
#    you can set SUPABASE_DB_SSL=false (not recommended for production).
# 4. Keep secrets out of VCS. Add .env to .gitignore if not already ignored.
